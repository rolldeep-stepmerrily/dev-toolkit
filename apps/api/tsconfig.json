{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@@decorators": ["src/common/decorators/index"],
      "@@entities": ["src/common/entities/index"],
      "@@exceptions": ["src/common/exceptions/index"],
      "@@pipes": ["src/common/pipes/index"],
      "@@prisma": ["src/generated/prisma/client"]
    }
  }
}
