{
  "name": "dev-toolkit",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @repo/api --filter @repo/web run dev",
    "build": "pnpm --recursive run build",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "typescript": "^5.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "bcrypt",
      "prisma",
      "sharp"
    ]
  }
}
