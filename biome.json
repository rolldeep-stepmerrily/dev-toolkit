{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "formatter": {
    "enabled": true,
    "lineWidth": 120,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      },
      "style": {
        "useExplicitType": "off"
      }
    }
  },
  "overrides": [
    {
      "include": [
        "**/*.strategy.ts",
        "**/*.controller.ts",
        "**/*.service.ts",
        "**/*.error.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useExplicitType": "error"
          }
        }
      }
    }
  ],
  "organizeImports": {
    "enabled": true
  },
  "files": {
    "ignore": ["**/dist/**", "**/node_modules/**", "**/build/**", "**/.next/**"]
  }
}
