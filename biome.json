{
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "attributePosition": "multiline",
    "lineWidth": 120,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "nursery": {
        "useExhaustiveSwitchCases": "error"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": "error",
        "noUselessStringConcat": "error",
        "noVoid": "error",
        "useDateNow": "error",
        "useSimplifiedLogicExpression": "error",
        "noUselessConstructor": "off"
      },
      "correctness": {
        "useSingleJsDocAsterisk": "error",
        "noUnusedImports": "error"
      },
      "style": {
        "useReadonlyClassProperties": "error",
        "useObjectSpread": "error",
        "noYodaExpression": "error",
        "noNamespace": "error",
        "useEnumInitializers": "error",
        "useDefaultSwitchClause": "error",
        "useExplicitLengthCheck": "error",
        "useForOf": "error",
        "useThrowNewError": "error",
        "useThrowOnlyError": "error",
        "useImportType": "off",
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "strictCase": true,
            "requireAscii": false,
            "filenameCases": ["kebab-case", "export"]
          }
        },
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false,
            "requireAscii": false,
            "conventions": [
              {
                "selector": {
                  "kind": "typeLike"
                },
                "formats": ["PascalCase"]
              },
              {
                "selector": {
                  "kind": "classProperty",
                  "modifiers": ["static"]
                },
                "formats": ["PascalCase"]
              },
              {
                "selector": {
                  "kind": "classProperty",
                  "modifiers": ["static", "readonly"]
                },
                "formats": ["PascalCase"]
              },
              {
                "selector": {
                  "kind": "objectLiteralMember"
                },
                "match": ".*|[$](.*?)",
                "formats": ["camelCase", "PascalCase"]
              },
              {
                "selector": {
                  "kind": "classMember"
                },
                "match": ".*|[ㄱ-ㅎ|ㅏ-ㅣ|가-힣](.*?)"
              }
            ]
          }
        },
        "useAsConstAssertion": "error",
        "useSingleVarDeclarator": "error",
        "noUnusedTemplateLiteral": "error",
        "useNumberNamespace": "error",
        "noUselessElse": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsole": "error",
        "noEmptyBlockStatements": "error",
        "useAwait": "error",
        "useErrorMessage": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}